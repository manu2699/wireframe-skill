{
  "name": "wireframe-preview",
  "version": "1.0.3",
  "description": "Generate fast, low-fidelity HTML wireframes to preview the UI/UX implications of a feature or change — for any AI agent harness.",
  "type": "module",
  "bin": {
    "wireframe-preview": "bin/cli.js",
    "wireframe-mcp": "mcp/server.js"
  },
  "files": [
    "bin/",
    "mcp/",
    "SKILL.md",
    "assets/"
  ],
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "test": "node test/smoke.mjs && node test/cli-mcp.mjs"
  },
  "keywords": [
    "claude",
    "cursor",
    "codex",
    "kilocode",
    "ai-agent",
    "skill",
    "wireframe",
    "ux",
    "feature-spec"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-solid": "^2.11.0"
  },
  "engines": {
    "node": ">=18"
  }
}