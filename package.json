{
  "name": "proto-frames",
  "version": "0.1.0",
  "description": "Generate fast, low-fidelity HTML wireframes to preview the UI/UX implications of a feature or change — for any AI agent harness.",
  "type": "module",
  "bin": {
    "proto-frames": "bin/cli.js",
    "proto-frames-mcp": "mcp/server.js"
  },
  "files": [
    "bin/",
    "mcp/",
    "SKILL.md",
    "assets/"
  ],
  "scripts": {
    "dev": "vite",
    "gen:sketch": "node scripts/gen-sketch-borders.mjs",
    "build": "npm run gen:sketch && tailwindcss -i app/styles/index.css -o assets/wireframe.css --minify && vite build",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "node test/smoke.mjs && node test/cli-mcp.mjs"
  },
  "keywords": [
    "claude",
    "cursor",
    "codex",
    "kilocode",
    "ai-agent",
    "skill",
    "wireframe",
    "ux",
    "feature-spec"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "motion": "^12.40.0"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "roughjs": "^4.6.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}